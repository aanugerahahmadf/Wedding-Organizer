{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "vite-build": "vite build",
        "deploy": "npm run prepare-deploy && vercel deploy --force --prod",
