    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-echo": "^2.3.0",
        "laravel-vite-plugin": "^2.0.0",
        "pusher-js": "^8.4.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    },
    "imports": {
        "#nativephp": "./vendor/nativephp/mobile/resources/dist/native.js"
    },
    "dependencies": {
        "@libsql/client": "^0.17.0",
        "filament-lang": "^0.5.3"
    }
